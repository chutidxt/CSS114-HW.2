// ค่าความคลาดเคลื่อนที่ยอมรับได้ (tolerance สำหรับการเปรียบเทียบ floating point)
const double EPS = 1e-9;

// ======================================================
// ฟังก์ชันแสดงผลเมทริกซ์
// ======================================================
void printMatrix(const vector<vector<double>>& M, const string& name) {
    int n = M.size();
    cout << name << " =\n";
    for (int i = 0; i < n; i++) {
        cout << "  [ ";
        for (int j = 0; j < n; j++) {
            // ป้องกันค่า -0.0 ที่อาจเกิดจาก floating point
            double val = (fabs(M[i][j]) < EPS) ? 0.0 : M[i][j];
            cout << setw(10) << fixed << setprecision(4) << val;
            if (j < n - 1) cout << "  ";
        }
        cout << " ]\n";
    }
    cout << "\n";
}

// ======================================================
// ฟังก์ชันแสดงผลเวกเตอร์
// ======================================================
void printVector(const vector<double>& v, const string& name) {
    cout << name << " = [ ";
    for (int i = 0; i < (int)v.size(); i++) {
        double val = (fabs(v[i]) < EPS) ? 0.0 : v[i];
        cout << fixed << setprecision(4) << val;
        if (i < (int)v.size() - 1) cout << ",  ";
    }
    cout << " ]^T\n";
}

// ======================================================
// ฟังก์ชันคูณเมทริกซ์ A * B
// ======================================================
vector<vector<double>> matMul(const vector<vector<double>>& A,
                               const vector<vector<double>>& B) {
    int n = A.size();
    vector<vector<double>> C(n, vector<double>(n, 0.0));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            for (int k = 0; k < n; k++)
                C[i][j] += A[i][k] * B[k][j];
    return C;
}

// ======================================================
// ฟังก์ชันหา determinant ของเมทริกซ์ (ใช้ Gaussian Elimination)
// ======================================================
double determinant(vector<vector<double>> M) {
    int n = M.size();
    double det = 1.0;
    for (int col = 0; col < n; col++) {
        // หา pivot (แถวที่มีค่า |M[row][col]| มากที่สุด)
        int pivot = -1;
        double maxVal = EPS;
        for (int row = col; row < n; row++) {
            if (fabs(M[row][col]) > maxVal) {
                maxVal = fabs(M[row][col]);
                pivot = row;
            }
        }
        if (pivot == -1) return 0.0; // singular matrix

        // สลับแถว
        if (pivot != col) {
            swap(M[pivot], M[col]);
            det *= -1.0; // การสลับแถวเปลี่ยนเครื่องหมาย det
        }

        det *= M[col][col];

        // ทำ elimination
        for (int row = col + 1; row < n; row++) {
            double factor = M[row][col] / M[col][col];
            for (int k = col; k < n; k++)
                M[row][k] -= factor * M[col][k];
        }
    }
    return det;
}

// ======================================================
// ฟังก์ชันหา Inverse ของเมทริกซ์ด้วย Gauss-Jordan Elimination
// คืนค่า true ถ้าหา inverse ได้, false ถ้า singular
// ======================================================
bool inverse(const vector<vector<double>>& A, vector<vector<double>>& inv) {
    int n = A.size();
    // สร้าง augmented matrix [A | I]
    vector<vector<double>> aug(n, vector<double>(2 * n, 0.0));
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) aug[i][j] = A[i][j];
        aug[i][n + i] = 1.0; // identity matrix ทางขวา
    }

    // Forward elimination
    for (int col = 0; col < n; col++) {
        int pivot = -1;
        double maxVal = EPS;
        for (int row = col; row < n; row++) {
            if (fabs(aug[row][col]) > maxVal) {
                maxVal = fabs(aug[row][col]);
                pivot = row;
            }
        }
        if (pivot == -1) return false; // ไม่มี inverse (singular)
        swap(aug[pivot], aug[col]);

        double diag = aug[col][col];
        for (int k = 0; k < 2 * n; k++) aug[col][k] /= diag;

        for (int row = 0; row < n; row++) {
            if (row == col) continue;
            double factor = aug[row][col];
            for (int k = 0; k < 2 * n; k++)
                aug[row][k] -= factor * aug[col][k];
        }
    }

    // ดึง inverse จากฝั่งขวาของ augmented matrix
    inv.assign(n, vector<double>(n));
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            inv[i][j] = aug[i][n + j];
    return true;
}

// ======================================================
// ฟังก์ชันแก้ระบบสมการ (A - lambda*I)v = 0
// ด้วย Gaussian Elimination เพื่อหา null space (eigenvector)
// ======================================================
vector<vector<double>> nullSpace(vector<vector<double>> M) {
    int n = M.size();
    vector<int> pivotCol(n, -1); // เก็บตำแหน่ง pivot ของแต่ละแถว

    int row = 0;
    for (int col = 0; col < n && row < n; col++) {
        // หา pivot
        int piv = -1;
        double maxVal = EPS;
        for (int r = row; r < n; r++) {
            if (fabs(M[r][col]) > maxVal) {
                maxVal = fabs(M[r][col]);
                piv = r;
            }
        }
        if (piv == -1) continue; // คอลัมน์นี้ไม่มี pivot (free variable)

        swap(M[piv], M[row]);
        pivotCol[row] = col;

        double diag = M[row][col];
        for (int k = 0; k < n; k++) M[row][k] /= diag;

        for (int r = 0; r < n; r++) {
            if (r == row) continue;
            double factor = M[r][col];
            for (int k = 0; k < n; k++)
                M[r][k] -= factor * M[row][k];
        }
        row++;
    }

    // หา free variables และสร้าง eigenvectors
    vector<bool> isFree(n, true);
    for (int r = 0; r < n; r++)
        if (pivotCol[r] != -1) isFree[pivotCol[r]] = false;

    vector<vector<double>> basis;
    for (int fc = 0; fc < n; fc++) {
        if (!isFree[fc]) continue;
        // สร้าง null vector โดยให้ free variable = 1, ตัวอื่น = 0
        vector<double> v(n, 0.0);
        v[fc] = 1.0;
        for (int r = 0; r < n; r++) {
            if (pivotCol[r] == -1) continue;
            v[pivotCol[r]] = -M[r][fc];
        }
        basis.push_back(v);
    }
    return basis;
}

// ======================================================
// ฟังก์ชัน normalize eigenvector ให้มี norm = 1
// ======================================================
vector<double> normalize(const vector<double>& v) {
    double norm = 0.0;
    for (double x : v) norm += x * x;
    norm = sqrt(norm);
    vector<double> res(v.size());
    if (norm < EPS) return v; // กรณี zero vector
    for (int i = 0; i < (int)v.size(); i++) res[i] = v[i] / norm;
    return res;
}

// ======================================================
// ฟังก์ชันหา Eigenvalues ของเมทริกซ์ 2x2
// characteristic polynomial: lambda^2 - tr(A)*lambda + det(A) = 0
// ======================================================
vector<double> eigenvalues2x2(const vector<vector<double>>& A) {
    double tr  = A[0][0] + A[1][1];           // trace
    double det = A[0][0]*A[1][1] - A[0][1]*A[1][0]; // determinant
    double disc = tr * tr - 4.0 * det;        // discriminant

    vector<double> eigs;
    if (disc < -EPS) {
        // eigenvalue เป็น complex (ไม่ diagonalizable เหนือ real)
        // ส่งค่าพิเศษเพื่อบอกว่าเป็น complex
        eigs.push_back(NAN);
    } else if (fabs(disc) <= EPS) {
        // repeated eigenvalue
        eigs.push_back(tr / 2.0);
        eigs.push_back(tr / 2.0);
    } else {
        // eigenvalue สองตัวต่างกัน
        eigs.push_back((tr + sqrt(disc)) / 2.0);
        eigs.push_back((tr - sqrt(disc)) / 2.0);
    }
    return eigs;
}

// ======================================================
// ฟังก์ชันหา Eigenvalues ของเมทริกซ์ 3x3
// characteristic polynomial: -lambda^3 + tr*lambda^2 - ...
// ใช้วิธี Cardano's formula / numeric root finding ด้วย companion matrix style
// ในที่นี้ใช้วิธีคำนวณ coefficients ของ char poly แล้ว solve cubics
// p(lambda) = lambda^3 - c2*lambda^2 + c1*lambda - c0 = 0
// ======================================================
vector<double> eigenvalues3x3(const vector<vector<double>>& A) {
    // trace และ sum of 2x2 principal minors และ determinant
    double c2 = A[0][0] + A[1][1] + A[2][2]; // trace

    // sum of principal 2x2 minors (c1)
    double c1 = (A[0][0]*A[1][1] - A[0][1]*A[1][0])
              + (A[0][0]*A[2][2] - A[0][2]*A[2][0])
              + (A[1][1]*A[2][2] - A[1][2]*A[2][1]);

    // determinant (c0)
    double c0 = A[0][0]*(A[1][1]*A[2][2] - A[1][2]*A[2][1])
              - A[0][1]*(A[1][0]*A[2][2] - A[1][2]*A[2][0])
              + A[0][2]*(A[1][0]*A[2][1] - A[1][1]*A[2][0]);

    // แก้ cubic: t^3 - c2*t^2 + c1*t - c0 = 0
    // แปลงเป็น depressed cubic ด้วย substitution t = x + c2/3
    // depressed cubic: t^3 + p*t + q = 0  (แทน lambda = t + c2/3)
    // p = c1 - c2^2/3
    // q ได้จากการ expand (t + c2/3)^3 - c2*(t+c2/3)^2 + c1*(t+c2/3) - c0 = 0
    //   constant term = -2c2^3/27 + c1*c2/3 - c0
    double p = c1 - c2 * c2 / 3.0;
    double q = -2.0 * c2 * c2 * c2 / 27.0 + c1 * c2 / 3.0 - c0;

    // discriminant ของ depressed cubic: D > 0 => 3 real roots
    double D = -(4.0 * p * p * p + 27.0 * q * q);

    vector<double> eigs;
    double shift = c2 / 3.0;

    if (D > EPS) {
        // 3 real distinct roots — ใช้ Viète's trigonometric formula
        // x_k = 2*sqrt(-p/3) * cos(1/3 * arccos(3q/(2p) * sqrt(-3/p)) - 2*pi*k/3)
        double sqrtTerm = 2.0 * sqrt(-p / 3.0);
        double cosArg   = (3.0 * q) / (2.0 * p) * sqrt(-3.0 / p);
        // clamp เพื่อป้องกัน floating point error ทำให้ acos domain error
        cosArg = max(-1.0, min(1.0, cosArg));
        double theta = acos(cosArg) / 3.0;

        eigs.push_back(sqrtTerm * cos(theta)                      + shift);
        eigs.push_back(sqrtTerm * cos(theta - 2.0 * M_PI / 3.0)  + shift);
        eigs.push_back(sqrtTerm * cos(theta - 4.0 * M_PI / 3.0)  + shift);
    } else if (fabs(D) <= EPS) {
        // repeated roots
        if (fabs(p) < EPS && fabs(q) < EPS) {
            // triple root
            eigs.push_back(shift);
            eigs.push_back(shift);
            eigs.push_back(shift);
        } else {
            // one simple + one double root
            // t0 = sqrt(-p/3) (sign follows q), double root; t1 = -2*t0, simple root
            double t0 = copysign(sqrt(fabs(-p / 3.0)), q);
            double t1 = -2.0 * t0;
            eigs.push_back(t1 + shift); // simple root
            eigs.push_back(t0 + shift); // double root
            eigs.push_back(t0 + shift);
        }
    } else {
        // complex roots (1 real, 2 complex conjugate) — ไม่ diagonalizable เหนือ real
        // หา real root เดียว (Cardano's formula)
        double disc = q * q / 4.0 + p * p * p / 27.0;
        double sqrtDisc = sqrt(disc);
        double A_c = cbrt(-q / 2.0 + sqrtDisc);
        double B_c = cbrt(-q / 2.0 - sqrtDisc);
        eigs.push_back(A_c + B_c + shift);
        eigs.push_back(NAN); // บ่งบอกว่ามี complex roots
        eigs.push_back(NAN);
    }
    return eigs;
}

// ======================================================
// โปรแกรมหลัก
// ======================================================
int main() {
    cout << "============================================\n";
    cout << "  Eigenvalue & Diagonalization Calculator\n";
    cout << "  Assignment #2 - CSS114\n";
    cout << "============================================\n\n";

    // รับขนาดเมทริกซ์
    int n;
    cout << "เลือกขนาดเมทริกซ์ (2 หรือ 3): ";
    cin >> n;
    if (n != 2 && n != 3) {
        cout << "Error: รองรับเฉพาะขนาด 2x2 และ 3x3 เท่านั้น\n";
        return 1;
    }

    // รับค่าเมทริกซ์ A
    vector<vector<double>> A(n, vector<double>(n));
    cout << "\nกรอกค่าเมทริกซ์ A ขนาด " << n << "x" << n
         << " (แถวละ " << n << " ค่า คั่นด้วยช่องว่าง):\n";
    for (int i = 0; i < n; i++) {
        cout << "  แถว " << i + 1 << ": ";
        for (int j = 0; j < n; j++) cin >> A[i][j];
    }

    cout << "\n";
    printMatrix(A, "เมทริกซ์ A");

    // ======================================================
    // ขั้นที่ 1: หา Eigenvalues
    // ======================================================
    cout << "--------------------------------------------\n";
    cout << " STEP 1: ค่าเจาะจง (Eigenvalues)\n";
    cout << "--------------------------------------------\n";

    vector<double> eigs = (n == 2) ? eigenvalues2x2(A) : eigenvalues3x3(A);

    // ตรวจสอบว่ามี complex eigenvalue หรือไม่
    bool hasComplex = false;
    for (double e : eigs) {
        if (isnan(e)) { hasComplex = true; break; }
    }

    if (hasComplex) {
        cout << "* พบ Eigenvalue เป็นจำนวนเชิงซ้อน (Complex)\n";
        cout << "  => เมทริกซ์นี้ไม่สามารถแปลงเป็นเมทริกซ์ทแยงมุมได้เหนือสนาม Real\n\n";
        return 0;
    }

    // แสดง eigenvalues
    for (int i = 0; i < (int)eigs.size(); i++) {
        cout << "  lambda_" << i + 1 << " = "
             << fixed << setprecision(4) << eigs[i] << "\n";
    }
    cout << "\n";

    // ======================================================
    // ขั้นที่ 2: หา Eigenvectors สำหรับแต่ละ Eigenvalue
    // ======================================================
    cout << "--------------------------------------------\n";
    cout << " STEP 2: เวกเตอร์เจาะจง (Eigenvectors)\n";
    cout << "--------------------------------------------\n";

    // eigenvalue ที่ unique (กำจัด duplicate เพื่อไม่ให้คำนวณซ้ำ)
    vector<double> uniqueEigs;
    for (double e : eigs) {
        bool found = false;
        for (double ue : uniqueEigs)
            if (fabs(e - ue) < EPS * 10) { found = true; break; }
        if (!found) uniqueEigs.push_back(e);
    }

    // เก็บ eigenvectors ทั้งหมด (columns ของ P)
    vector<vector<double>> eigVecs; // แต่ละ element คือ eigenvector หนึ่งตัว

    for (double lambda : uniqueEigs) {
        cout << "  lambda = " << fixed << setprecision(4) << lambda << ":\n";

        // สร้าง (A - lambda*I)
        vector<vector<double>> AminLI(n, vector<double>(n));
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                AminLI[i][j] = A[i][j] - (i == j ? lambda : 0.0);
            }
        }

        // หา null space = eigenvectors
        vector<vector<double>> basis = nullSpace(AminLI);

        if (basis.empty()) {
            cout << "    ไม่พบ eigenvector (เกิดข้อผิดพลาด)\n";
        } else {
            for (int k = 0; k < (int)basis.size(); k++) {
                vector<double> nv = normalize(basis[k]);
                eigVecs.push_back(nv);
                cout << "    v_" << eigVecs.size() << " = [ ";
                for (int i = 0; i < n; i++) {
                    double val = (fabs(nv[i]) < EPS) ? 0.0 : nv[i];
                    cout << fixed << setprecision(4) << val;
                    if (i < n - 1) cout << ",  ";
                }
                cout << " ]^T  (normalized)\n";
            }
        }
    }
    cout << "\n";

    // ======================================================
    // ขั้นที่ 3: ตรวจสอบว่า Diagonalizable หรือไม่
    // เมทริกซ์ n×n diagonalizable ก็ต่อเมื่อมี n eigenvectors อิสระเชิงเส้น
    // ======================================================
    cout << "--------------------------------------------\n";
    cout << " STEP 3: ตรวจสอบการ Diagonalize\n";
    cout << "--------------------------------------------\n";

    bool isDiagonalizable = ((int)eigVecs.size() == n);

    if (!isDiagonalizable) {
        cout << "* ผลการตรวจสอบ: ไม่สามารถแปลงเป็นเมทริกซ์ทแยงมุมได้\n\n";
        cout << "  เหตุผล:\n";
        cout << "  - เมทริกซ์ขนาด " << n << "x" << n
             << " ต้องการ " << n << " eigenvectors ที่อิสระเชิงเส้น\n";
        cout << "  - แต่หาได้เพียง " << eigVecs.size() << " eigenvector\n";
        cout << "  - นั่นหมายความว่ามี eigenvalue ซ้ำที่มี geometric multiplicity\n";
        cout << "    น้อยกว่า algebraic multiplicity (eigenvectors ไม่เพียงพอ)\n";
        cout << "  - ดังนั้น เมทริกซ์นี้เป็น defective matrix และไม่ diagonalizable\n";
        return 0;
    }

    cout << "* ผลการตรวจสอบ: สามารถแปลงเป็นเมทริกซ์ทแยงมุมได้\n";
    cout << "  (มี " << n << " eigenvectors อิสระเชิงเส้นครบถ้วน)\n\n";

    // ======================================================
    // ขั้นที่ 4: สร้าง P, P^{-1} และ D
    // P = matrix ที่แต่ละคอลัมน์คือ eigenvector
    // D = diagonal matrix ของ eigenvalues
    // D = P^{-1} * A * P
    // ======================================================
    cout << "--------------------------------------------\n";
    cout << " STEP 4: เมทริกซ์ P, P^-1 และ D\n";
    cout << "--------------------------------------------\n";

    // สร้าง P (columns = eigenvectors)
    vector<vector<double>> P(n, vector<double>(n));
    for (int j = 0; j < n; j++)
        for (int i = 0; i < n; i++)
            P[i][j] = eigVecs[j][i];

    // สร้าง D (diagonal = eigenvalues ตามลำดับ eigenvectors)
    vector<vector<double>> D(n, vector<double>(n, 0.0));
    // จับคู่ eigenvector กับ eigenvalue ที่ถูกต้อง
    // โดยดูว่า A * v = lambda * v
    for (int j = 0; j < n; j++) {
        // คำนวณ A * v_j
        vector<double> Av(n, 0.0);
        for (int i = 0; i < n; i++)
            for (int k = 0; k < n; k++)
                Av[i] += A[i][k] * eigVecs[j][k];

        // หา lambda: Av[i] / v[i] สำหรับ component ที่ไม่ใช่ 0
        double lambda = 0.0;
        for (int i = 0; i < n; i++) {
            if (fabs(eigVecs[j][i]) > EPS) {
                lambda = Av[i] / eigVecs[j][i];
                break;
            }
        }
        D[j][j] = lambda;
    }

    // หา P^{-1}
    vector<vector<double>> Pinv;
    if (!inverse(P, Pinv)) {
        cout << "Error: ไม่สามารถหา inverse ของ P ได้ (P เป็น singular)\n";
        return 1;
    }

    printMatrix(P, "P (คอลัมน์คือ eigenvectors)");
    printMatrix(Pinv, "P^-1");
    printMatrix(D, "D = P^-1 * A * P (เมทริกซ์ทแยงมุม)");

    // ======================================================
    // ตรวจสอบความถูกต้อง: D = P^-1 * A * P
    // ======================================================
    cout << "--------------------------------------------\n";
    cout << " การตรวจสอบ: P^-1 * A * P ควรเท่ากับ D\n";
    cout << "--------------------------------------------\n";

    vector<vector<double>> check = matMul(matMul(Pinv, A), P);

    // ทำความสะอาดค่า near-zero
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            if (fabs(check[i][j]) < EPS) check[i][j] = 0.0;

    printMatrix(check, "P^-1 * A * P (ผลตรวจสอบ)");

    // ตรวจสอบว่าตรงกับ D หรือไม่
    bool verified = true;
    for (int i = 0; i < n && verified; i++)
        for (int j = 0; j < n && verified; j++)
            if (fabs(check[i][j] - D[i][j]) > 1e-6) verified = false;

    if (verified)
        cout << "✓ ตรวจสอบผ่าน: P^-1 * A * P = D อย่างถูกต้อง\n\n";
    else
        cout << "✗ ตรวจสอบไม่ผ่าน: อาจเกิดจาก numerical error\n\n";

    cout << "============================================\n";
    cout << "  การคำนวณเสร็จสมบูรณ์\n";
    cout << "============================================\n";

    return 0;
}
